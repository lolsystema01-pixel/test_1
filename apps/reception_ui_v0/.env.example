# Web受付UI v0.4
#
# ★ 接続先は「検証環境」のSupabaseのみ（本番ではない）。anonキーだけを使う（RLSが効く公開可キー）。
#   ・状況参照／番号存在チェックは SECURITY DEFINER 関数 delivery_status_public(anon可・非PII) を呼ぶ。
#   ・OTP送信・受付登録はアプリ内ダミーのまま（実SMS=チャネル連携、受付テーブルは別指示書）。
#   ・未設定なら全部アプリ内ダミーで動く（オフライン検証可）。
#
# 検証Supabase（ダッシュボード → Project Settings → API）。PUBLIC_ 接頭辞が必須。
PUBLIC_SUPABASE_URL=
PUBLIC_SUPABASE_ANON_KEY=

# 前提：検証Supabaseに delivery_status_public 関数が作成済みであること
#   （supabase/ai_status_reply_v0/delivery_status_rpc_v0.sql）。

# ── 受付チャネル（任意）。★ PUBLIC_ を付けないこと＝サーバ専用（クライアントに出さない）。
#    未設定なら署名はスタブ通過・返信/SMSはログ（検証）。設定した分だけ実連携に切替。
# N-7 LINE（LINE Developers Console → Messaging API チャネル）
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=
# N-8 SMS（Twilio等。双方向/通知を実送信する場合のみ）
SMS_PROVIDER_SID=
SMS_PROVIDER_TOKEN=
SMS_FROM=
