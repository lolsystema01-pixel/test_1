# これはテンプレートです。コピーして .env を作り、実際の値を入れてください。
#   コピー(PowerShell): Copy-Item .env.example .env
# .env は .gitignore 済み。これは Cloud Run(Hono) のサーバ環境変数。フロントには無い。
#
# ★ Claude API キー = サーバ専用。フロント・レスポンス・ログに出さない（要件定義 11.3）。
ANTHROPIC_API_KEY=sk-ant-...

# モデル（未指定なら claude-opus-4-8）
ANTHROPIC_MODEL=claude-opus-4-8

# Supabase（anonキー）。問合番号→非PII状況は SECURITY DEFINER 関数経由で引く＝service_role不要。
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# 待受ポート（既定 8787）
PORT=8787
