# これはテンプレートです。コピーして .env を作り、実際の値を入れてください。
#   コピー方法(PowerShell):  Copy-Item .env.example .env
# .env は .gitignore 済みなのでコミットされません。

# --- Supabase REST API 用（supabase-js / supabase-py で使用） ---
# ダッシュボード → Project Settings → API から取得
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
# サーバー側のみで使用。漏らさないこと（RLSを無視できる強い権限）
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --- DB へ直接接続する場合（psql / pg / psycopg で使用） ---
# ダッシュボード → Project Settings → Database → Connection string
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.xxxxxxxxxxxx.supabase.co:5432/postgres

# --- Google OAuth（内部向け認証 / 認証v0.3）※任意・参考 ---
# ホスティング版Supabaseで運用する場合、ID/シークレットはダッシュボードに入力した時点で
# Supabase側に保存される（暗号化保管）。ログインだけならこの.envは不要。
# ここに名前を置くのは、ローカルのSupabase CLI(config.toml)やCloud Run等から扱う場合のみ。
# （クライアントIDは秘密ではない／シークレットは秘密。値はコミットしない）
# SUPABASE_AUTH_GOOGLE_CLIENT_ID=your-google-client-id
# SUPABASE_AUTH_GOOGLE_SECRET=your-google-client-secret
